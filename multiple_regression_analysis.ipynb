      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Coefficients and final linear equation (using model params)\n",
        "params = model.params\n",
        "print('Model coefficients:\n', params)\n",
        "# Construct human-readable equation\n",
        "intercept = params.get('const', 0.0)\n",
        "terms = []\n",
        "for name, coeff in params.items():\n",
        "    if name == 'const':\n",
        "        continue\n",
        "    terms.append(f'({coeff:.4f})*{name}')\n",
        "equation = 'Sales = ' + f'{intercept:.4f}' + ' + ' + ' + '.join(terms)\n",
        "print('\nEstimated linear equation:\n', equation)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Next steps (optional automations)\n",
